DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bottle_erp
DB_SSL=false
JWT_SECRET=replace_with_long_random_secret

# Landing contact form (Web3Forms). Create a key at https://web3forms.com — public key (embedded in browser bundle).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Aiven: DB_SSL=true. Download ca.pem from Aiven → DB_SSL_CA_PATH=.../ca.pem (best).
# Without ca.pem, TLS still works with rejectUnauthorized=false (default when CA unset).
# DB_SSL_REJECT_UNAUTHORIZED=true only if you use DB_SSL_CA_PATH and want to enforce.
